<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#1E1E30"
    android:orientation="vertical"
    android:minHeight="400dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="#2A2A3E">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Edit Widget"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_edit_widget_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#8888AA"
                android:textSize="12sp" />

        </LinearLayout>

        <Button
            android:id="@+id/btn_edit_cancel"
            android:layout_width="88dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:text="Cancel"
            android:textColor="#AAAACC"
            android:textSize="13sp"
            style="@style/Widget.Material3.Button.OutlinedButton" />

        <Button
            android:id="@+id/btn_edit_save"
            android:layout_width="88dp"
            android:layout_height="40dp"
            android:text="Save"
            android:textSize="13sp"
            android:backgroundTint="#4FC3F7"
            android:textColor="#000000"
            style="@style/Widget.Material3.Button" />

    </LinearLayout>

    <!-- Scrollable config content — reuses the same field layout as the wizard Step 3 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="false"
        android:scrollbars="vertical"
        android:scrollbarStyle="insideOverlay">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SCALE SETTINGS"
                android:textColor="#888899"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <!-- Min / Max -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Min value"
                        android:textColor="#AAAACC"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/et_range_min"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal|numberSigned"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#444456"
                        android:padding="10dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Max value"
                        android:textColor="#AAAACC"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/et_range_max"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal|numberSigned"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#444456"
                        android:padding="10dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Major tick / Minor ticks -->
            <LinearLayout
                android:id="@+id/row_ticks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Major tick interval"
                        android:textColor="#AAAACC"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/et_major_tick"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#444456"
                        android:padding="10dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Minor subdivisions"
                        android:textColor="#AAAACC"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/et_minor_ticks"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#444456"
                        android:padding="10dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Warning threshold + Decimal places -->
            <LinearLayout
                android:id="@+id/row_warning_decimals"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Warning threshold (optional)"
                        android:textColor="#AAAACC"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/et_warning"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal|numberSigned"
                        android:hint="none"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#555566"
                        android:backgroundTint="#444456"
                        android:padding="10dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Decimal places"
                        android:textColor="#AAAACC"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/et_decimal_places"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#444456"
                        android:padding="10dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Display unit -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Display unit"
                android:textColor="#AAAACC"
                android:textSize="12sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/et_display_unit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:textColor="#FFFFFF"
                android:backgroundTint="#444456"
                android:padding="10dp"
                android:layout_marginBottom="20dp" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#333344"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SIZE PRESET"
                android:textColor="#888899"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="10dp" />

            <!-- Size preset chips -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <Button
                    android:id="@+id/btn_size_small"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="36dp"
                    android:text="S"
                    android:textSize="12sp"
                    android:layout_marginEnd="6dp"
                    style="@style/Widget.Material3.Button.TonalButton" />

                <Button
                    android:id="@+id/btn_size_medium"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="36dp"
                    android:text="M"
                    android:textSize="12sp"
                    android:layout_marginEnd="6dp"
                    style="@style/Widget.Material3.Button.TonalButton" />

                <Button
                    android:id="@+id/btn_size_large"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="36dp"
                    android:text="L"
                    android:textSize="12sp"
                    android:layout_marginEnd="6dp"
                    style="@style/Widget.Material3.Button.TonalButton" />

                <Button
                    android:id="@+id/btn_size_wide"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="36dp"
                    android:text="Wide"
                    android:textSize="12sp"
                    android:layout_marginEnd="6dp"
                    style="@style/Widget.Material3.Button.TonalButton" />

                <Button
                    android:id="@+id/btn_size_tall"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="36dp"
                    android:text="Tall"
                    android:textSize="12sp"
                    style="@style/Widget.Material3.Button.TonalButton" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_size_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Medium: 4 × 4 grid units"
                android:textColor="#666677"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
