<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#1E1E30"
    android:orientation="vertical"
    android:minHeight="400dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="#2A2A3E">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Edit Widget"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_edit_widget_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#8888AA"
                android:textSize="12sp" />

        </LinearLayout>

        <Button
            android:id="@+id/btn_edit_cancel"
            android:layout_width="88dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:text="Cancel"
            android:textColor="#AAAACC"
            android:textSize="13sp"
            style="@style/Widget.Material3.Button.OutlinedButton" />

        <Button
            android:id="@+id/btn_edit_save"
            android:layout_width="88dp"
            android:layout_height="40dp"
            android:text="Save"
            android:textSize="13sp"
            android:backgroundTint="#4FC3F7"
            android:textColor="#000000"
            style="@style/Widget.Material3.Button" />

    </LinearLayout>

    <!-- Scrollable config content — reuses the same field layout as the wizard Step 3 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="vertical"
        android:scrollbarStyle="insideOverlay">

        <include layout="@layout/widget_properties_editor" />

    </ScrollView>

</LinearLayout>
