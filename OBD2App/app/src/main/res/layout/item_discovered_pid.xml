<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardBackgroundColor="#1A1A2E"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    android:foreground="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Header row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <CheckBox
                android:id="@+id/checkbox_selected"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:buttonTint="#4FC3F7" />

            <TextView
                android:id="@+id/tv_pid_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Extended PID 0456"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_pid_bytes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2 bytes"
                android:textColor="#888888"
                android:textSize="11sp"
                android:background="#0D0D1A"
                android:padding="4dp" />

        </LinearLayout>

        <!-- Command row -->
        <TextView
            android:id="@+id/tv_pid_command"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="760 220456"
            android:textColor="#4FC3F7"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="2dp" />

        <!-- Response row -->
        <TextView
            android:id="@+id/tv_pid_response"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="62 04 56 01 F4"
            android:textColor="#66BB6A"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="4dp" />

        <!-- Formula row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_pid_formula"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Formula: ((A*256)+B)/100"
                android:textColor="#CCCCCC"
                android:textSize="11sp"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/tv_pid_unit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="°/s"
                android:textColor="#FFA726"
                android:textSize="11sp"
                android:background="#0D0D1A"
                android:padding="2dp"
                android:layout_marginStart="8dp"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
