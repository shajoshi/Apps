<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/device_row_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="14dp"
    android:paddingEnd="8dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <!-- BT icon -->
    <ImageView
        android:id="@+id/icon_bt"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginEnd="12dp"
        android:src="@drawable/ic_bluetooth"
        android:contentDescription="Bluetooth"
        android:tint="#4FC3F7" />

    <!-- Device info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/text_device_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E0E0E0"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_device_address"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#888888"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- "Connected" badge -->
    <TextView
        android:id="@+id/badge_connected"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:background="@drawable/badge_connected_bg"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:text="CONNECTED"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- Disconnect icon (shown only when this row is connected) -->
    <ImageView
        android:id="@+id/icon_disconnect"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:contentDescription="Disconnect"
        android:padding="6dp"
        android:src="@drawable/ic_link_off"
        android:tint="#CF6679"
        android:visibility="gone" />

</LinearLayout>
