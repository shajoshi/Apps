<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:orientation="vertical"
    tools:context=".ui.connect.ConnectFragment">

    <!-- Top bar with title, scan icon and overflow menu -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#1A1A2E"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="4dp">

        <TextView
            android:id="@+id/txt_top_bar_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/connect_title"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btn_scan"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/scan_for_devices"
            android:padding="8dp"
            android:src="@drawable/ic_scan"
            android:tint="#4FC3F7" />

        <ImageButton
            android:id="@+id/btn_top_overflow"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="More options"
            android:src="@drawable/ic_settings_black_24dp"
            android:tint="#AAAAAA" />

    </LinearLayout>

    <!-- content padding wrapper -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

    <!-- Status line -->
    <TextView
        android:id="@+id/text_connect_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="@string/status_disconnected"
        android:textColor="#888888"
        android:textSize="14sp" />

    <!-- Paired devices section -->
    <TextView
        android:id="@+id/label_paired"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:text="@string/paired_devices"
        android:textColor="#AAAACC"
        android:textSize="13sp"
        android:textStyle="bold" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerview_devices"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="4dp" />

    <!-- Discovered (nearby) devices section -->
    <TextView
        android:id="@+id/label_discovered"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        android:text="@string/nearby_devices"
        android:textColor="#AAAACC"
        android:textSize="13sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerview_discovered"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="4dp"
        android:visibility="gone" />

    <!-- Connection log panel — visible during/after a connection attempt -->
    <LinearLayout
        android:id="@+id/panel_connection_log"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0D0D1A"
        android:padding="10dp"
        android:layout_marginTop="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/label_log_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CONNECTION LOG"
            android:textColor="#666677"
            android:textSize="10sp"
            android:letterSpacing="0.08"
            android:layout_marginBottom="6dp" />

        <ScrollView
            android:id="@+id/scroll_log"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="160dp"
            android:fillViewport="false"
            android:scrollbars="vertical"
            android:scrollbarStyle="insideOverlay">

            <TextView
                android:id="@+id/text_connection_log"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:lineSpacingExtra="2dp"
                android:textColor="#AAAACC"
                android:textSize="11sp" />

        </ScrollView>

    </LinearLayout>

    <!-- Disconnect button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_disconnect"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:backgroundTint="#CF6679"
        android:text="@string/disconnect"
        android:textColor="#FFFFFF"
        android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
