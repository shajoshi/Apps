<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:orientation="vertical"
    tools:context=".ui.connect.ConnectFragment">

    <!-- Top bar with title, scan icon and overflow menu -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#1A1A2E"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="4dp">

        <TextView
            android:id="@+id/txt_top_bar_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/connect_title"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btn_scan"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/scan_for_devices"
            android:padding="8dp"
            android:src="@drawable/ic_scan"
            android:tint="#4FC3F7" />

        <ImageButton
            android:id="@+id/btn_top_overflow"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="More options"
            android:src="@drawable/ic_more_vert"
            android:tint="#AAAAAA" />

    </LinearLayout>

    <!-- Force BLE toggle section -->
    <LinearLayout
        android:id="@+id/panel_force_ble"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0D0D1A"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Force BLE"
            android:textColor="#E0E0E0"
            android:textSize="14sp" />

        <ImageButton
            android:id="@+id/btn_ble_info"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="BLE info"
            android:padding="2dp"
            android:src="@android:drawable/ic_menu_info_details"
            android:tint="#AAAAAA" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_force_ble"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="false" />

    </LinearLayout>

    <!-- CAN Trace Recording panel (visible only when CAN Bus logging is enabled) -->
    <LinearLayout
        android:id="@+id/panel_can_trace"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0D0D1A"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:visibility="gone">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_record_can_trace"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Record CAN Trace"
            android:textAllCaps="false"
            android:textColor="#4FC3F7" />

        <Space
            android:layout_width="8dp"
            android:layout_height="1dp" />

        <TextView
            android:id="@+id/tv_trace_line_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 lines"
            android:textColor="#AAAAAA"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- content padding wrapper -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <!-- Status line -->
        <TextView
            android:id="@+id/text_connect_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="@string/status_disconnected"
            android:textColor="#888888"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/panel_device_list_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="3"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/panel_device_list_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingBottom="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Devices"
                    android:textColor="#AAAACC"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/btn_device_list_toggle"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Expand or collapse device list"
                    android:padding="6dp"
                    android:src="@drawable/ic_chevron_up"
                    android:tint="#AAAAAA" />
            </LinearLayout>

            <!-- Unified device list with section headers -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerview_devices"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="true"
                android:paddingBottom="4dp"
                android:scrollbars="vertical" />
        </LinearLayout>

        <!-- Connection log panel — always visible -->
        <LinearLayout
            android:id="@+id/panel_connection_log"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#0D0D1A"
            android:padding="10dp"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/label_log_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CONNECTION LOG"
                android:textColor="#666677"
                android:textSize="10sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp" />

            <ScrollView
                android:id="@+id/scroll_log"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true"
                android:nestedScrollingEnabled="true"
                android:scrollbars="vertical"
                android:scrollbarStyle="insideOverlay">

                <TextView
                    android:id="@+id/text_connection_log"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="2dp"
                    android:textColor="#AAAACC"
                    android:textSize="11sp" />

            </ScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_copy_log"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Copy log"
                    android:textAllCaps="false" />

                <Space
                    android:layout_width="8dp"
                    android:layout_height="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_debug_export"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Debug"
                    android:textAllCaps="false" />
            </LinearLayout>

        </LinearLayout>

        <!-- Disconnect button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_disconnect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:backgroundTint="#CF6679"
            android:text="@string/disconnect"
            android:textColor="#FFFFFF"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
