<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#0A0A1A"
    android:orientation="vertical"
    android:padding="20dp"
    android:minHeight="600dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="PID Discovery"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Close"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

    </LinearLayout>

    <!-- Scan Options -->
    <LinearLayout
        android:id="@+id/layout_scan_options"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1A1A2E"
        android:layout_marginBottom="16dp">

        <!-- Collapsible header -->
        <LinearLayout
            android:id="@+id/layout_scan_options_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Scan Options"
                android:textColor="#4FC3F7"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/iv_scan_options_caret"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/arrow_up_float"
                android:contentDescription="Toggle scan options"
                app:tint="#4FC3F7" />

        </LinearLayout>

        <!-- Collapsible content -->
        <LinearLayout
            android:id="@+id/layout_scan_options_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="12dp"
            android:paddingBottom="12dp">

        <!-- Headers -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ECU Headers:"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <CheckBox
                android:id="@+id/checkbox_header_7E0"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="7E0 (Engine)"
                android:textColor="#CCCCCC"
                android:textSize="11sp"
                android:buttonTint="#4FC3F7" />

            <CheckBox
                android:id="@+id/checkbox_header_7E1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="7E1 (Trans)"
                android:textColor="#CCCCCC"
                android:textSize="11sp"
                android:buttonTint="#4FC3F7" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <CheckBox
                android:id="@+id/checkbox_header_7E2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="7E2 (ABS)"
                android:textColor="#CCCCCC"
                android:textSize="11sp"
                android:buttonTint="#4FC3F7" />

            <CheckBox
                android:id="@+id/checkbox_header_760"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="760 (Inst)"
                android:textColor="#CCCCCC"
                android:textSize="11sp"
                android:buttonTint="#4FC3F7" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <CheckBox
                android:id="@+id/checkbox_header_7E4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="7E4 (Hybrid)"
                android:textColor="#CCCCCC"
                android:textSize="11sp"
                android:buttonTint="#4FC3F7" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

        </LinearLayout>

        <!-- Modes -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Modes:"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <CheckBox
                android:id="@+id/checkbox_mode_21"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Mode 21"
                android:textColor="#CCCCCC"
                android:textSize="11sp"
                android:buttonTint="#4FC3F7" />

            <CheckBox
                android:id="@+id/checkbox_mode_22"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Mode 22"
                android:textColor="#CCCCCC"
                android:textSize="11sp"
                android:buttonTint="#4FC3F7" />

            <CheckBox
                android:id="@+id/checkbox_mode_23"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Mode 23"
                android:textColor="#CCCCCC"
                android:textSize="11sp"
                android:buttonTint="#4FC3F7" />

        </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Control Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_start_discovery"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Start Discovery"
            android:layout_marginEnd="8dp"
            app:backgroundTint="#4FC3F7" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_stop_discovery"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Stop"
            android:layout_marginEnd="8dp"
            android:visibility="gone"
            app:backgroundTint="#FF5252" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_reset"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Reset"
            android:visibility="gone"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

    </LinearLayout>

    <!-- Progress -->
    <LinearLayout
        android:id="@+id/progress_discovery"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/progress_discovery_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:progressTint="#4FC3F7" />

        <TextView
            android:id="@+id/tv_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Scanning..."
            android:textColor="#CCCCCC"
            android:textSize="12sp"
            android:gravity="center" />

    </LinearLayout>

    <!-- Tabs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tab_console"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Console"
            android:textColor="#4FC3F7"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="8dp"
            android:background="#1A1A2E"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tab_results"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Results"
            android:textColor="#CCCCCC"
            android:textSize="14sp"
            android:gravity="center"
            android:padding="8dp"
            android:background="#0D0D1A"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- Console Tab -->
    <LinearLayout
        android:id="@+id/layout_console"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="#0D0D1A"
        android:padding="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DISCOVERY LOG"
            android:textColor="#666677"
            android:textSize="10sp"
            android:letterSpacing="0.08"
            android:layout_marginBottom="6dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_console"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="vertical"
            android:scrollbarStyle="insideOverlay" />

    </LinearLayout>

    <!-- Results Tab -->
    <LinearLayout
        android:id="@+id/layout_results"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="#0D0D1A"
        android:padding="8dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="DISCOVERED PIDS"
                android:textColor="#666677"
                android:textSize="10sp"
                android:letterSpacing="0.08" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_selected"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add Selected (0)"
                android:textSize="11sp"
                android:enabled="false"
                style="@style/Widget.MaterialComponents.Button.TextButton" />

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_results"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="vertical"
            android:scrollbarStyle="insideOverlay" />

    </LinearLayout>

</LinearLayout>
