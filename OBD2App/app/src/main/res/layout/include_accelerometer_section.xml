<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Power Values -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Accel Power"
                android:textColor="#888888"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_power_accel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="— kW"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thermo Power"
                android:textColor="#888888"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_power_thermo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="— kW"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OBD Power"
                android:textColor="#888888"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_power_obd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="— kW"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

    <!-- Vertical Acceleration -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vert Accel RMS"
                android:textColor="#888888"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_accel_vert_rms"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="— m/s²"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vert Accel Max"
                android:textColor="#888888"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_accel_vert_max"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="— m/s²"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vert Accel Mean"
                android:textColor="#888888"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_accel_vert_mean"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="— m/s²"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

    <!-- Forward/Lateral Acceleration -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fwd Accel RMS"
                android:textColor="#888888"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_accel_fwd_rms"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="— m/s²"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lat Accel RMS"
                android:textColor="#888888"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_accel_lat_rms"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="— m/s²"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lean Angle"
                android:textColor="#888888"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_accel_lean_angle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="— °"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

    <!-- Sample Count -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sample Count"
                android:textColor="#888888"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_accel_sample_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
