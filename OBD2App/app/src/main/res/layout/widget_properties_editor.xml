<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Metric Selection -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="DATA SOURCE"
        android:textColor="#888899"
        android:textSize="11sp"
        android:letterSpacing="0.08"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tv_current_metric"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#2A2A3E"
        android:padding="12dp"
        android:textColor="#4FC3F7"
        android:textSize="14sp"
        android:layout_marginBottom="16dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SCALE SETTINGS"
        android:textColor="#888899"
        android:textSize="11sp"
        android:letterSpacing="0.08"
        android:layout_marginBottom="8dp" />

    <!-- Min / Max -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Min value"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/et_range_min"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal|numberSigned"
                android:textColor="#FFFFFF"
                android:backgroundTint="#444456"
                android:padding="10dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Max value"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/et_range_max"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal|numberSigned"
                android:textColor="#FFFFFF"
                android:backgroundTint="#444456"
                android:padding="10dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Major tick / Minor ticks -->
    <LinearLayout
        android:id="@+id/row_ticks"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Major tick interval"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/et_major_tick"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal|numberSigned"
                android:textColor="#FFFFFF"
                android:backgroundTint="#444456"
                android:padding="10dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Minor tick count"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/et_minor_ticks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="#FFFFFF"
                android:backgroundTint="#444456"
                android:padding="10dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Warning threshold / Decimal places -->
    <LinearLayout
        android:id="@+id/row_warning_decimals"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Warning threshold"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/et_warning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal|numberSigned"
                android:textColor="#FFFFFF"
                android:backgroundTint="#444456"
                android:padding="10dp"
                android:hint="Optional" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Decimal places"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/et_decimal_places"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="#FFFFFF"
                android:backgroundTint="#444456"
                android:padding="10dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Display unit -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Display unit"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinner_display_unit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp"
            android:backgroundTint="#444456" />

        <EditText
            android:id="@+id/et_custom_unit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:backgroundTint="#444456"
            android:padding="10dp"
            android:hint="Enter custom unit"
            android:layout_marginTop="8dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Size presets -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SIZE PRESET"
        android:textColor="#888899"
        android:textSize="11sp"
        android:letterSpacing="0.08"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/btn_size_small"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginEnd="2dp"
            android:text="S"
            android:textSize="11sp"
            android:textColor="#AAAACC"
            style="@style/Widget.Material3.Button.OutlinedButton" />

        <Button
            android:id="@+id/btn_size_medium"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:text="M"
            android:textSize="11sp"
            android:textColor="#AAAACC"
            style="@style/Widget.Material3.Button.OutlinedButton" />

        <Button
            android:id="@+id/btn_size_large"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:text="L"
            android:textSize="11sp"
            android:textColor="#AAAACC"
            style="@style/Widget.Material3.Button.OutlinedButton" />

        <Button
            android:id="@+id/btn_size_wide"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:text="Wide"
            android:textSize="11sp"
            android:textColor="#AAAACC"
            style="@style/Widget.Material3.Button.OutlinedButton" />

        <Button
            android:id="@+id/btn_size_tall"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="2dp"
            android:text="Tall"
            android:textSize="11sp"
            android:textColor="#AAAACC"
            style="@style/Widget.Material3.Button.OutlinedButton" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_size_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Current size: 4×4 grid cells"
        android:textColor="#666677"
        android:textSize="11sp"
        android:layout_marginBottom="16dp" />

</LinearLayout>
