<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <!-- In-screen top strip -->
    <LinearLayout
        android:id="@+id/top_strip"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:background="#1A1A2E"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Back -->
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            android:tint="#FFFFFF"
            android:contentDescription="Back" />

        <!-- Dashboard name + EDITING badge -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp">

            <TextView
                android:id="@+id/txt_dashboard_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/badge_editing"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="#CCFF8F00"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="EDITING"
                android:textColor="#FFFFFF"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Undo button (visible only when there are unsaved changes) -->
        <ImageButton
            android:id="@+id/btn_undo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            android:tint="#FFC107"
            android:visibility="gone"
            android:contentDescription="Undo" />

        <!-- Save button (visible only in edit mode with unsaved changes) -->
        <ImageButton
            android:id="@+id/btn_save"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_save"
            android:tint="#66BB6A"
            android:visibility="gone"
            android:contentDescription="Save" />

        <!-- Trip: Play -->
        <ImageButton
            android:id="@+id/btn_trip_play"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_play"
            android:tint="#4FC3F7"
            android:contentDescription="Start trip" />

        <!-- Trip: Pause -->
        <ImageButton
            android:id="@+id/btn_trip_pause"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_pause"
            android:tint="#FFC107"
            android:visibility="gone"
            android:contentDescription="Pause trip" />

        <!-- Trip: Stop -->
        <ImageButton
            android:id="@+id/btn_trip_stop"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_delete"
            android:tint="#EF5350"
            android:visibility="gone"
            android:contentDescription="Stop trip" />

        <!-- Map Orientation Toggle -->
        <ImageButton
            android:id="@+id/btn_map_orientation"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_compass"
            android:tint="#FFFFFF"
            android:alpha="0.5"
            android:contentDescription="Toggle map orientation" />

        <!-- Reset Min/Max -->
        <ImageButton
            android:id="@+id/btn_reset_minmax"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_rotate"
            android:tint="#9C27B0"
            android:visibility="gone"
            android:contentDescription="Reset min/max values" />

        <!-- Edit toggle (pencil = enter edit; check = exit edit) -->
        <ImageButton
            android:id="@+id/btn_edit_toggle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_edit"
            android:tint="#AAAAAA"
            android:contentDescription="Toggle edit mode" />

        <!-- Overflow ⋮ (settings / color scheme etc.) -->
        <ImageButton
            android:id="@+id/btn_overflow"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_settings_black_24dp"
            android:tint="#AAAAAA"
            android:contentDescription="More options" />

    </LinearLayout>

    <!-- Canvas host — fills remaining space; canvas_container is sized to match in code -->
    <FrameLayout
        android:id="@+id/canvas_scroll_h"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipChildren="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/top_strip">

            <!-- The actual drawing canvas for widgets; size set programmatically to match parent -->
            <FrameLayout
                android:id="@+id/canvas_container"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- Grid overlay — fills canvas -->
                <com.sj.obd2app.ui.dashboard.GridOverlayView
                    android:id="@+id/grid_overlay"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone" />

            </FrameLayout>

    </FrameLayout>

    <!-- FAB: Add Widget — visible only in edit mode -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_widget"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_input_add"
        android:contentDescription="Add widget"
        android:visibility="gone"
        app:backgroundTint="#FF8F00"
        app:tint="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Widget inline action toolbar — shown above selected widget in edit mode -->
    <LinearLayout
        android:id="@+id/widget_action_bar"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:background="#CC1A1A2E"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:elevation="8dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@+id/top_strip"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/wab_edit"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_edit"
            android:tint="#4FC3F7"
            android:contentDescription="Edit widget" />

        <ImageButton
            android:id="@+id/wab_front"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_ff"
            android:tint="#AAAACC"
            android:contentDescription="Bring to front" />

        <ImageButton
            android:id="@+id/wab_back"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_rew"
            android:tint="#AAAACC"
            android:contentDescription="Send to back" />

        <ImageButton
            android:id="@+id/wab_delete"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_delete"
            android:tint="#EF5350"
            android:contentDescription="Delete widget" />

    </LinearLayout>

    <!-- Property Editor Panel (shown when a widget is selected in edit mode) -->
    <LinearLayout
        android:id="@+id/panel_properties"
        android:layout_width="250dp"
        android:layout_height="0dp"
        android:background="#E62A2A3E"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/top_strip">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Widget Properties"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btn_close_properties"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="#FFFFFF" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_bring_front"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Bring to Front" />

        <Button
            android:id="@+id/btn_send_back"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Send to Back" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Transparency:"
            android:textColor="#AAAAAA" />

        <SeekBar
            android:id="@+id/slider_alpha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="100" />

        <Button
            android:id="@+id/btn_delete_widget"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:backgroundTint="#D32F2F"
            android:text="Delete Widget" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
