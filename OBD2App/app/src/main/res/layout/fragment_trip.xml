<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- Top bar -->
        <include
            android:id="@+id/top_bar_include"
            layout="@layout/include_top_bar"
            android:layout_width="match_parent"
            android:layout_height="48dp" />

        <!-- ── Sensor Readiness ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#16213E"
            app:cardCornerRadius="10dp"
            app:cardElevation="4dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SENSOR READINESS"
                    android:textColor="#4FC3F7"
                    android:textSize="15sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold"
                    android:paddingBottom="10dp" />

                <!-- OBD2 row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="10dp">

                    <View
                        android:id="@+id/indicator_obd"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/circle_indicator"
                        android:backgroundTint="#888888" />

                    <TextView
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:text="OBD2"
                        android:textColor="#CCCCCC"
                        android:textSize="18sp"
                        android:layout_marginStart="10dp" />

                    <TextView
                        android:id="@+id/tv_obd_status"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="—"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp" />

                </LinearLayout>

                <!-- GPS row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="10dp">

                    <View
                        android:id="@+id/indicator_gps"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/circle_indicator"
                        android:backgroundTint="#888888" />

                    <TextView
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:text="GPS"
                        android:textColor="#CCCCCC"
                        android:textSize="18sp"
                        android:layout_marginStart="10dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_gps_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp" />

                        <TextView
                            android:id="@+id/tv_gps_detail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="#AAAAAA"
                            android:textSize="11sp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Accel row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="10dp">

                    <View
                        android:id="@+id/indicator_accel"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/circle_indicator"
                        android:backgroundTint="#888888" />

                    <TextView
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:text="Accel"
                        android:textColor="#CCCCCC"
                        android:textSize="13sp"
                        android:layout_marginStart="10dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_accel_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tv_accel_power"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="#AAAAAA"
                            android:textSize="11sp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Logging row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:id="@+id/indicator_logging"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/circle_indicator"
                        android:backgroundTint="#888888" />

                    <TextView
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:text="Logging"
                        android:textColor="#CCCCCC"
                        android:textSize="13sp"
                        android:layout_marginStart="10dp" />

                    <TextView
                        android:id="@+id/tv_logging_status"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="—"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>


        <!-- ── Trip Status ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="10dp"
            app:cardBackgroundColor="#16213E"
            app:cardCornerRadius="10dp"
            app:cardElevation="4dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="TRIP"
                    android:textColor="#4FC3F7"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold"
                    android:paddingBottom="10dp" />

                <!-- Phase + Samples -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Phase"
                            android:textColor="#888888"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tv_trip_phase"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="IDLE"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Samples"
                            android:textColor="#888888"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tv_trip_samples"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Duration + Distance -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Duration"
                            android:textColor="#888888"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tv_trip_duration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="00:00"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Distance"
                            android:textColor="#888888"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tv_trip_distance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0 km"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Avg Speed -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Avg Speed"
                            android:textColor="#888888"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tv_avg_speed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="— km/h"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Altitude"
                            android:textColor="#888888"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tv_altitude"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="— m"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Coolant Temp + Avg Fuel (kmpl) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Coolant Temp"
                            android:textColor="#888888"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/tv_coolant_temp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="— °C"
                            android:textColor="#FFFFFF"
                            android:textSize="21sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Avg Fuel"
                            android:textColor="#888888"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/tv_avg_fuel_kmpl"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="— kmpl"
                            android:textColor="#FFFFFF"
                            android:textSize="21sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Fuel Cost + Idle % -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fuel Cost"
                            android:textColor="#888888"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/tv_fuel_cost"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="— ₹"
                            android:textColor="#FFFFFF"
                            android:textSize="21sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Idle %"
                            android:textColor="#888888"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/tv_idle_percent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="— %"
                            android:textColor="#FFFFFF"
                            android:textSize="21sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

                <!-- City % + Highway % -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="City %"
                            android:textColor="#888888"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/tv_city_percent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="— %"
                            android:textColor="#FFFFFF"
                            android:textSize="21sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Highway %"
                            android:textColor="#888888"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/tv_highway_percent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="— %"
                            android:textColor="#FFFFFF"
                            android:textSize="21sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Power Thermo BHP + Power OBD BHP -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Power Thermo"
                            android:textColor="#888888"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/tv_power_thermo_bhp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="— BHP"
                            android:textColor="#FFFFFF"
                            android:textSize="21sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Power - Accel"
                            android:textColor="#888888"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/tv_power_obd_bhp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="— BHP"
                            android:textColor="#FFFFFF"
                            android:textSize="21sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ── Orientation (only when accel enabled) ── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_gravity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="10dp"
            android:visibility="gone"
            app:cardBackgroundColor="#16213E"
            app:cardCornerRadius="10dp"
            app:cardElevation="4dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <!-- Collapsible header row -->
                <LinearLayout
                    android:id="@+id/gravity_header_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="8dp"
                    android:background="?attr/selectableItemBackground">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="ORIENTATION"
                        android:textColor="#4FC3F7"
                        android:textSize="15sp"
                        android:letterSpacing="0.1"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/iv_gravity_chevron"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_chevron_up"
                        android:tint="#4FC3F7"
                        android:contentDescription="Collapse orientation" />

                </LinearLayout>

                <!-- Collapsible body -->
                <LinearLayout
                    android:id="@+id/gravity_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_gravity_values"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="X: —   Y: —   Z: —"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/tv_gravity_magnitude"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="— g"
                        android:textColor="#AAAAAA"
                        android:textSize="18sp"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/tv_gravity_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Awaiting trip start…"
                        android:textColor="#888888"
                        android:textSize="17sp" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ── Trip Control Buttons ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="16dp"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_start"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="Start"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                app:backgroundTint="#2E7D32"
                app:cornerRadius="8dp"
                xmlns:app="http://schemas.android.com/apk/res-auto" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pause"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="3dp"
                android:text="Pause"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:backgroundTint="#E65100"
                app:cornerRadius="8dp"
                xmlns:app="http://schemas.android.com/apk/res-auto" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_stop"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="Stop"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:backgroundTint="#B71C1C"
                app:cornerRadius="8dp"
                xmlns:app="http://schemas.android.com/apk/res-auto" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
