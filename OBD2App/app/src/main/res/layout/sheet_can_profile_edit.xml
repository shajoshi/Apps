<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#16213E"
    android:padding="16dp">

    <!-- ── Header row with title, Cancel, Save ─────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/tv_sheet_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="New CAN Profile"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_can_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="Cancel"
            android:textColor="#AAAAAA"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

        <Button
            android:id="@+id/btn_can_save"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Save"
            android:textColor="#4FC3F7"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

    </LinearLayout>

    <!-- ── Profile settings header with caret toggle ───────────────────────── -->
    <LinearLayout
        android:id="@+id/ll_profile_settings_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:background="?attr/selectableItemBackground"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Profile settings"
            android:textColor="#4FC3F7"
            android:textSize="13sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btn_settings_toggle"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_chevron_up"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Collapse settings"
            android:tint="#4FC3F7" />

    </LinearLayout>

    <!-- ── Collapsible settings panel ─────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/ll_settings_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="4dp">

        <EditText
            android:id="@+id/et_can_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Profile name"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:inputType="text"
            android:importantForAutofill="no"
            android:autofillHints="none" />

        <EditText
            android:id="@+id/et_can_objective"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Objective (short description)"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:inputType="text"
            android:importantForAutofill="no"
            android:autofillHints="none" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sampling (ms)"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/et_sampling_ms"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:hint="500"
                android:inputType="number"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:importantForAutofill="no"
                android:autofillHints="none" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sync ticker (Hz)"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/et_sync_ticker_hz"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:hint="1–200"
                android:inputType="number"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:importantForAutofill="no"
                android:autofillHints="none" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="Hz  (1–200)"
                android:textColor="#888888"
                android:textSize="11sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Record raw CAN frames during scan"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/sw_record_raw"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <!-- Visible only in mock mode: lets the user bypass DBC loading entirely -->
        <LinearLayout
            android:id="@+id/ll_use_demo_data"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Use built-in demo data (no DBC needed)"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/sw_use_demo_data"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_dbc_file_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="middle"
                android:singleLine="true"
                android:text="No DBC file loaded"
                android:textColor="#AAAAAA"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_pick_dbc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Load DBC…"
                android:textColor="#4FC3F7"
                style="@style/Widget.MaterialComponents.Button.TextButton" />

        </LinearLayout>

        <!-- Playback capture (used only in mock mode to replay a recorded session) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_capture_file_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="middle"
                android:singleLine="true"
                android:text="Playback: none (mock uses synthetic frames)"
                android:textColor="#AAAAAA"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_clear_capture"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Clear"
                android:textColor="#E57373"
                android:visibility="gone"
                style="@style/Widget.MaterialComponents.Button.TextButton" />

            <Button
                android:id="@+id/btn_pick_capture"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Load capture…"
                android:textColor="#4FC3F7"
                style="@style/Widget.MaterialComponents.Button.TextButton" />

        </LinearLayout>

    </LinearLayout>
    <!-- ── End collapsible settings panel ────────────────────────────────── -->

    <!-- ── Trip Attribute Mapping card ───────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="vertical"
        android:background="#1A1A2E">

        <!-- Header row with toggle caret -->
        <LinearLayout
            android:id="@+id/ll_mapping_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Trip Attribute Mapping"
                android:textColor="#4FC3F7"
                android:textSize="13sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btn_mapping_toggle"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_chevron_up"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Expand mapping"
                android:tint="#4FC3F7"
                android:rotation="180" />

        </LinearLayout>

        <!-- Mapping body (collapsed by default) -->
        <LinearLayout
            android:id="@+id/ll_mapping_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingBottom="8dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="Map CAN signals to Trip screen metrics. Auto-populated from signal names — adjust if needed."
                android:textColor="#888888"
                android:textSize="11sp" />

            <!-- Action buttons row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:orientation="horizontal"
                android:gravity="end">

                <TextView
                    android:id="@+id/btn_mapping_auto_fill"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:text="Auto-fill"
                    android:textColor="#4FC3F7"
                    android:textSize="12sp"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:background="?attr/selectableItemBackground" />

                <TextView
                    android:id="@+id/btn_mapping_clear_all"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Clear all"
                    android:textColor="#FF6B6B"
                    android:textSize="12sp"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:background="?attr/selectableItemBackground" />

            </LinearLayout>

            <!-- Empty-state shown when no DBC is loaded -->
            <TextView
                android:id="@+id/tv_mapping_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Load a DBC file to enable signal mapping."
                android:textColor="#666666"
                android:textSize="12sp"
                android:visibility="gone" />

            <!-- Rows injected programmatically -->
            <LinearLayout
                android:id="@+id/ll_mapping_rows"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>

    </LinearLayout>
    <!-- ── End Trip Attribute Mapping card ───────────────────────────────── -->

    <!-- Selected signals section (chips) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selected signals"
            android:textColor="#4FC3F7"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:id="@+id/ll_selected_signals"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="4dp"
            android:background="#1A1A2E" />

        <TextView
            android:id="@+id/tv_selected_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:text="No signals selected"
            android:textColor="#666666"
            android:textSize="11sp"
            android:visibility="gone" />

    </LinearLayout>

    <EditText
        android:id="@+id/et_signal_filter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Filter signals…"
        android:textColor="#FFFFFF"
        android:textColorHint="#666666"
        android:inputType="text"
        android:importantForAutofill="no"
        android:autofillHints="none" />

    <TextView
        android:id="@+id/tv_selection_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="0 signals selected"
        android:textColor="#4FC3F7"
        android:textSize="12sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_signals"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="6dp"
        android:background="#1A1A2E"
        android:scrollbars="vertical"
        android:scrollbarStyle="insideOverlay"
        android:scrollbarThumbVertical="@drawable/scrollbar_thumb_cyan"
        android:scrollbarSize="4dp"
        android:fadeScrollbars="false"
        tools:listitem="@layout/item_can_signal" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:gravity="start">

        <Button
            android:id="@+id/btn_can_delete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Delete"
            android:textColor="#E57373"
            android:visibility="gone"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

    </LinearLayout>

</LinearLayout>
