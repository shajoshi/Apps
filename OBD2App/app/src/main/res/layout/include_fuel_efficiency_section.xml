<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Instant Consumption + Efficiency -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Instant Consumption"
                android:textColor="#888888"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_instant_consumption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="— L/100km"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Instant Efficiency"
                android:textColor="#888888"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_instant_efficiency"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="— km/L"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

    <!-- Trip Fuel Used + Average Consumption -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trip Fuel Used"
                android:textColor="#888888"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_trip_fuel_used"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="— L"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Avg Consumption"
                android:textColor="#888888"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_trip_avg_consumption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="— L/100km"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

    <!-- Average Efficiency + Fuel Cost -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Avg Efficiency"
                android:textColor="#888888"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_trip_avg_efficiency"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="— km/L"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fuel Cost"
                android:textColor="#888888"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_fuel_cost_estimate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="— $"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

    <!-- Range Remaining + CO2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Range Remaining"
                android:textColor="#888888"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_range_remaining"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="— km"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CO₂ Emissions"
                android:textColor="#888888"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_co2_emissions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="— g/km"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
